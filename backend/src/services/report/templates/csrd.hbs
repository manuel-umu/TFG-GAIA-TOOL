<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>CSRD Sustainability Report — {{organization.name}}</title>
    <style>
      {{{_styles}}}
    </style>
  </head>
  <body>

    <!-- PORTADA -->
    <div class="cover-page">
      {{#if organization.logo_url}}
      <div class="cover-top">
        <img src="{{organization.logo_url}}" class="cover-logo" alt="{{organization.name}}" />
      </div>
      {{/if}}

      <div class="cover-center">
        {{#unless organization.logo_url}}
          <p class="cover-brand">GAIA-TOOL</p>
        {{/unless}}
        <h1 class="cover-title">Sustainability Statement<br>under CSRD</h1>
        <p class="cover-org">{{organization.name}}</p>
        {{#if audit.reporting_year}}
          <p class="cover-year">Fiscal Year {{audit.reporting_year}}</p>
        {{/if}}
        <p class="cover-subtitle">
          Prepared in accordance with the<br>
          European Sustainability Reporting Standards (ESRS)
        </p>
      </div>

      <div class="cover-footer">
        <div class="cover-footer-item"><b>Auditor:</b> {{auditor.name}}</div>
        <div class="cover-footer-item"><b>Manager:</b> {{manager.name}}</div>
        <div class="cover-footer-item"><b>Generated:</b> {{formatDate generatedAt}}</div>
      </div>
    </div>

    <h2 class="section">1. Audit Information</h2>
    <ul class="info-list">
      <li><b>Name:</b> {{audit.name}}</li>
      {{#if audit.description}}<li><b>Description:</b>
          {{audit.description}}</li>{{/if}}
      <li><b>Organization:</b> {{organization.name}}</li>
      <li><b>Auditor:</b> {{auditor.name}}</li>
      <li><b>Manager:</b> {{manager.name}}</li>
      <li><b>Framework:</b> {{framework.code}}</li>
      <li><b>Period:</b>
        {{formatDate audit.init_date}}
        &rarr;
        {{formatDate audit.end_date}}</li>
    </ul>

    <h2 class="section">2. Double Materiality Assessment</h2>
    <table class="report-table">
      <thead>
        <tr>
          <th>Code</th>
          <th>Standard</th>
          <th>Category</th>
          <th>Mandatory</th>
          <th>Materiality</th>
          <th>Justification</th>
        </tr>
      </thead>
      <tbody>
        {{#each materiality.standards as |s|}}
          <tr>
            <td>{{s.code}}</td>
            <td>{{s.name}}</td>
            <td>{{s.category}}</td>
            <td>{{#if s.is_mandatory}}Yes{{else}}No{{/if}}</td>
            <td>{{#if s.assessment}}{{#if
                  s.assessment.is_material
                }}Material{{else}}Not material{{/if}}{{else}}-{{/if}}</td>
            <td>{{#if
                s.assessment.justification
              }}{{s.assessment.justification}}{{else}}-{{/if}}</td>
          </tr>
        {{/each}}
      </tbody>
    </table>

    <h2 class="section">3. CSRD DataPoints</h2>
    {{#each questionnaire.standards as |std|}}
      {{#if std.has_content}}
        <h3>{{std.code}} &mdash; {{std.name}}</h3>
        {{#each std.disclosure_requirements as |dr|}}
          <p class="dr-heading">{{dr.code}} &mdash; {{dr.name}}</p>
          {{#if dr.reported_data_points.length}}
            <table class="report-table">
              <thead>
                <tr>
                  <th>ID</th>
                  <th>DataPoint</th>
                  <th>Type</th>
                  <th>Value</th>
                  <th>Evidence</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
                {{#each dr.reported_data_points as |dp|}}
                  <tr>
                    <td>{{dp.official_id}}</td>
                    <td>{{dp.name}}</td>
                    <td>{{dp.data_type}}</td>
                    <td>{{formatDataPointValue dp.response dp.data_type}}</td>
                    <td>{{#if
                        dp.response.evidence_reference
                      }}{{dp.response.evidence_reference}}{{else}}-{{/if}}</td>
                    <td>{{dp.response.status}}</td>
                  </tr>
                {{/each}}
              </tbody>
            </table>
          {{/if}}
          {{#if dr.na_data_points.length}}
            <p class="na-heading">Not applicable to this organization</p>
            <table class="report-table na-table">
              <thead>
                <tr>
                  <th>ID</th>
                  <th>DataPoint</th>
                  <th>Reason</th>
                </tr>
              </thead>
              <tbody>
                {{#each dr.na_data_points as |dp|}}
                  <tr>
                    <td>{{dp.official_id}}</td>
                    <td>{{dp.name}}</td>
                    <td>{{#if
                        dp.response.value_text
                      }}{{dp.response.value_text}}{{else}}Not applicable{{/if}}</td>
                  </tr>
                {{/each}}
              </tbody>
            </table>
          {{/if}}
        {{/each}}
      {{/if}}
    {{/each}}

  </body>
</html>